              <span className="label-code text-[var(--sw-red)]">WITHOUT ACCELERATOR</span>
              <span className="font-head text-[32px] md:text-[40px] leading-none text-white/70 tabular-nums">12–18 mo</span>
            </div>
            <ul className="space-y-3 text-[14px] text-white/75">
              {[
                "Agency learns what SIC codes are on your budget",
