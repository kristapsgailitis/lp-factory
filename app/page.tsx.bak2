import {
  ArrowRight,
  ArrowUpRight,
  Check,
  Plus,
  Minus,
} from "lucide-react";

/* ==================================================================
   SCHOOL PHOTOGRAPHY COMMERCE — productized LP
   scandiweb brand: Secular One (head) + Inter (body) + JetBrains Mono (label).
   Primary accent: scandiweb Red #E04F4F. Page base: #10132C (scandiweb Black).
   ================================================================== */

/* ------------------------------------------------------------------
   Primitives
   ------------------------------------------------------------------ */

/* Buttons — outline only, per scandiweb.com Homepage v2 pattern.
   On dark bg: 1px beige stroke + beige text, transparent fill.
   On light bg: 1px blue stroke + blue text, transparent fill.
   Height 48px · padding 32×12 · radius 2px · Golos 600 17px. */
const btnPrimary =
  "inline-flex h-12 items-center justify-center gap-2 rounded-[2px] border border-[var(--sw-beige)] bg-transparent text-[var(--sw-beige)] px-8 text-[17px] hover:bg-[var(--sw-beige)] hover:text-[var(--sw-black)] transition font-head font-semibold";
const btnSecondary =
  "inline-flex h-12 items-center justify-center gap-2 rounded-[2px] border border-white/30 bg-transparent text-white/80 px-8 text-[17px] hover:border-white/60 hover:text-white transition font-head font-semibold";
const btnOutline = btnSecondary; // alias kept for existing usages
const btnGhost =
  "inline-flex items-center gap-2 rounded-[2px] text-white/80 px-3 py-1.5 text-[15px] hover:text-white transition font-head font-semibold";

function SectionLabel({ index, children }: { index?: string; children: React.ReactNode }) {
  return (
    <div className="label-code mb-5 inline-flex items-center gap-3">
      {index && <span className="text-white/55">{index}</span>}
      {index && <span className="h-px w-6 bg-white/15" />}
      <span>{children}</span>
    </div>
  );
}

function Stat({ value, label, accent }: { value: string; label: string; accent?: string }) {
  return (
    <div className="flex flex-col gap-2 min-w-0">
      <div
        className="font-head text-[40px] md:text-[52px] lg:text-[64px] leading-none tabular-nums"
        style={{ color: accent ?? "var(--sw-white)" }}
      >
        {value}
      </div>
      <div className="label-code text-[10px] leading-snug">{label}</div>
    </div>
  );
}

/* ------------------------------------------------------------------
   Top strip
   ------------------------------------------------------------------ */


/* ------------------------------------------------------------------
   Header
   ------------------------------------------------------------------ */

function Header() {
  return (
    <header className="hairline-b bg-[var(--lp-bg)]/85 backdrop-blur sticky top-0 z-40">
      <div className="wrap flex items-center justify-between py-5">
        <a href="#" className="font-head text-xl tracking-tight text-white">
          scandiweb
          <span className="text-white/40"> · school photography commerce</span>
        </a>
        <div className="flex items-center gap-3">
          <a href="#cta" className="hidden md:inline-flex items-center gap-2 label-code text-white/70 hover:text-white">
            Configuration consultation
            <ArrowRight className="h-3 w-3" />
          </a>
          <a
            href="#cta"
            className="inline-flex h-9 items-center gap-2 rounded-[2px] border border-[var(--sw-beige)] bg-transparent text-[var(--sw-beige)] px-5 text-[14px] hover:bg-[var(--sw-beige)] hover:text-[var(--sw-black)] transition font-head font-semibold"
          >
            Book a walkthrough
            <ArrowRight className="h-3.5 w-3.5" />
          </a>
        </div>
      </div>
    </header>
  );
}

/* ------------------------------------------------------------------
   Hero — with balanced right-side "system status" panel
   ------------------------------------------------------------------ */

function SystemStatusPanel() {
  return (
    <div className="rounded-[4px] border border-white/10 bg-[var(--lp-bg-elev)] overflow-hidden">
      {/* Panel header */}
      <div className="flex items-center justify-between px-5 py-3.5 hairline-b bg-[var(--lp-bg)]/40">
        <div className="flex items-center gap-2 label-code text-white/70">
          <span className="h-1.5 w-1.5 rounded-full bg-[var(--sw-green)] pulse-green" />
          <span>Reference · production · Q1 2025</span>
        </div>
        <div className="flex gap-1.5">
          <span className="h-2 w-2 rounded-full bg-white/15" />
          <span className="h-2 w-2 rounded-full bg-white/15" />
          <span className="h-2 w-2 rounded-full bg-[var(--sw-green)]" />
        </div>
      </div>

      {/* Metric tiles */}
      <div className="grid grid-cols-2 gap-px bg-white/5">
        {[
          { k: "44,891", sub: "students on MDM · day one", a: "var(--sw-white)" },
          { k: "14 wk", sub: "kickoff → MVP in prod", a: "var(--sw-white)" },
          { k: "5 / 0", sub: "legacy integrated / decommissioned", a: "var(--sw-white)" },
          { k: "0", sub: "peak-season incidents · Q1 2025", a: "var(--sw-green)" },
        ].map((m, i) => (
          <div key={i} className="bg-[var(--lp-bg-elev)] p-5">
            <div className="font-head text-3xl md:text-4xl leading-none tabular-nums" style={{ color: m.a }}>
              {m.k}
            </div>
            <div className="label-code mt-3 text-[10px] leading-snug">{m.sub}</div>
          </div>
        ))}
      </div>

      {/* System status rows */}
      <div className="px-5 py-4 hairline-t">
        {[
          ["DATA MODEL", "NORMALIZED · AUDIT-LOGGED", "ok"],
          ["SCHOOL PORTAL", "SELF-SERVICE · IP-ALLOWLIST", "ok"],
          ["BATCH EXPORT", "AUTOMATED · 10 FORMATS", "ok"],
          ["ID CARDS", "ORDER · PREVIEW · EXPORT", "ok"],
          ["SSO", "COGNITO + ENTRA ID", "ok"],
          ["INTEGRATIONS", "5 LEGACY · LIVE", "ok"],
        ].map(([k, v], i) => (
          <div
            key={i}
            className="flex items-center justify-between py-2 label-code text-white/75 border-b border-white/5 last:border-0"
          >
            <span className="text-white/55">{k}</span>
            <span className="flex items-center gap-2">
              <span>{v}</span>
              <span className="h-1.5 w-1.5 rounded-full bg-[var(--sw-green)] tick-fade" />
            </span>
          </div>
        ))}
      </div>
    </div>
  );
}

/* Blue gradient hero background — approximates the signature scandiweb wavy texture.
   Layered radial gradients create the "organic ribbon" feel without needing a raster image. */
function HeroBg() {
  return (
    <>
      <div
        className="absolute inset-0 -z-10"
        style={{
          background:
            "radial-gradient(1200px 700px at 15% 20%, #5a67c9 0%, transparent 55%)," +
            "radial-gradient(900px 600px at 85% 80%, #1a1f5e 0%, transparent 50%)," +
            "radial-gradient(1400px 900px at 50% 50%, #3f4aaf 0%, #3f4aaf 35%, #2a3288 70%, #1e2470 100%)",
        }}
      />
      <div
        className="absolute inset-0 -z-10 opacity-40 mix-blend-overlay"
        style={{
          background:
            "radial-gradient(600px 900px at 30% 60%, rgba(16, 19, 44, 0.55), transparent 60%)," +
            "radial-gradient(500px 700px at 70% 30%, rgba(255, 255, 255, 0.12), transparent 60%)",
          filter: "blur(30px)",
        }}
      />
      {/* Very subtle grid */}
      <div
        className="absolute inset-0 -z-10 opacity-[0.08]"
        style={{
          backgroundImage:
            "linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px),linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px)",
          backgroundSize: "80px 80px",
        }}
      />
    </>
  );
}

function HeroCaseCard() {
  return (
    <a
      href="#launch"
      className="group block rounded-[4px] bg-[var(--lp-bg-elev)]/70 backdrop-blur border border-white/15 overflow-hidden max-w-[420px] ml-auto hover:border-white/30 transition"
    >
      {/* Visual tile — schematic case-study render */}
      <div className="relative aspect-[16/10] bg-gradient-to-br from-[#2a3288] via-[#1f256e] to-[#10132c] overflow-hidden">
        <svg viewBox="0 0 400 250" className="absolute inset-0 w-full h-full" aria-hidden>
          {/* Soft organic band */}
          <defs>
            <radialGradient id="rg" cx="30%" cy="40%" r="70%">
              <stop offset="0%" stopColor="#6EF76E" stopOpacity="0.28" />
              <stop offset="60%" stopColor="#3F4AAF" stopOpacity="0" />
            </radialGradient>
          </defs>
          <rect width="400" height="250" fill="url(#rg)" />
          {/* Mini wireframe: dashboard tiles */}
          <g transform="translate(32,36)" stroke="rgba(255,255,255,0.18)" strokeWidth="1" fill="none">
            <rect x="0" y="0" width="336" height="36" rx="2" />
            <text x="12" y="23" fill="rgba(255,255,255,0.7)" fontFamily="JetBrains Mono" fontSize="11" letterSpacing="1.5">
              REFERENCE · PRODUCTION
            </text>
            <circle cx="316" cy="18" r="3" fill="#6EF76E" />
          </g>
          <g transform="translate(32,96)">
            {[[0,"44,891","students"],[110,"14 wk","to live"],[220,"0","incidents"]].map(([x,v,l],i)=>(
              <g key={i} transform={`translate(${x as number},0)`}>
                <rect width="104" height="86" rx="2" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.14)" />
                <text x="12" y="40" fill="#ffffff" fontFamily="Golos Text" fontSize="22" fontWeight="700">{v as string}</text>
                <text x="12" y="66" fill="rgba(255,255,255,0.55)" fontFamily="JetBrains Mono" fontSize="9" letterSpacing="1">{(l as string).toUpperCase()}</text>
              </g>
            ))}
          </g>
          <g transform="translate(32,200)" stroke="rgba(255,255,255,0.14)" strokeWidth="1" fill="none">
            <rect x="0" y="0" width="336" height="26" rx="2" fill="rgba(255,255,255,0.03)" />
            <text x="12" y="17" fill="rgba(255,255,255,0.55)" fontFamily="JetBrains Mono" fontSize="9" letterSpacing="1.5">
              MODULES · PORTAL · EXPORT · ID · SSO · INTEGRATION
            </text>
          </g>
        </svg>
      </div>
      {/* Card body */}
      <div className="flex items-start justify-between p-5 gap-4">
        <div>
          <div className="label-code mb-2 text-white/55">CASE STUDY · Q1 2025</div>
          <div className="font-head text-[17px] leading-snug text-white">
            Fourteen weeks to production on Australia’s national school photography operator. Drama-free launch.
          </div>
        </div>
        <ArrowUpRight className="h-5 w-5 shrink-0 text-white/70 mt-0.5 group-hover:text-white group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition" />
      </div>
    </a>
  );
}

function Hero() {
  return (
    <section className="relative overflow-hidden">
      <HeroBg />
      <div className="wrap relative z-10 pt-20 md:pt-28 pb-16 md:pb-24">
        <div className="grid gap-12 lg:grid-cols-[1.4fr_1fr] items-start">
          {/* Left column — copy */}
          <div>
            {/* Pill eyebrow — uppercase, outline in white */}
            <div className="inline-flex items-center rounded-[2px] border border-white/60 px-3 py-1.5 mb-10">
              <span className="font-head text-[12px] font-semibold tracking-[0.14em] text-white uppercase">
                School photography commerce
              </span>
            </div>

            {/* H1 — all mint green (scandiweb title-slide pattern) */}
            <h1
              className="font-head text-[44px] sm:text-[56px] md:text-[72px] lg:text-[88px] leading-[1.02] tracking-[-0.01em] max-w-[16ch]"
              style={{ color: "var(--sw-mint)" }}
            >
              School photography operations, finally self-running
            </h1>

            {/* Subhead — white with bold emphasis */}
            <p className="mt-8 text-[16px] md:text-[18px] text-white max-w-[56ch] leading-relaxed">
              A pre-built operations stack for school photography operators —
              student data, self-service school portal, automated batch exports,
              ID card workflow, dual SSO, and legacy integrations.{" "}
              <span className="font-bold">Live in 14 weeks</span>, adapted to your schools and your ERP.
            </p>

            {/* Scroll indicator */}
            <div className="mt-16 md:mt-24 flex items-center gap-3 text-white/70">
              <span className="inline-flex h-6 w-6 items-center justify-center rounded-full border border-white/60">
                <svg viewBox="0 0 24 24" className="h-3 w-3" fill="none" stroke="currentColor" strokeWidth="2">
                  <path d="M12 5v14M6 13l6 6 6-6" strokeLinecap="round" strokeLinejoin="round" />
                </svg>
              </span>
              <span className="label-code">Scroll to discover</span>
            </div>
          </div>

          {/* Right column — case-study promo card */}
          <div className="lg:pt-24">
            <HeroCaseCard />
          </div>
        </div>
      </div>

      {/* Trust strip — anonymized proof */}
      <div className="relative z-10 border-t border-white/15 bg-[rgba(16,19,44,0.35)] backdrop-blur">
        <div className="wrap py-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
          <div className="max-w-[22ch] md:max-w-none">
            <div className="font-head font-bold text-[14px] text-white leading-tight">
              Proven live on Australia’s national school photography operator
            </div>
          </div>
          <div className="flex flex-wrap items-center gap-x-10 gap-y-3 label-code text-white/70">
            <span>44,891 students on MDM · day one</span>
            <span className="text-white/30">·</span>
            <span>14 weeks to production</span>
            <span className="text-white/30">·</span>
            <span>0 peak-season incidents</span>
            <span className="text-white/30">·</span>
            <span>5 legacy systems live · 0 decommissioned</span>
          </div>
        </div>
      </div>
    </section>
  );
}

/* ------------------------------------------------------------------
   Marquee proof strip (was: stats collision)
   ------------------------------------------------------------------ */

function MarqueeStrip() {
  const items = [
    "44,891 students on MDM · day one",
    "14 weeks · kickoff to MVP in production",
    "0 peak-season incidents · Q1 2025",
    "500 GB student images migrated off on-prem",
    "10 batch export formats configured",
    "5 legacy systems integrated · 0 decommissioned mid-project",
    "Dual SSO · AWS Cognito + Microsoft Entra ID",
    "IP-allowlist · admin VPN · audit-logged end to end",
  ];
  const doubled = [...items, ...items];
  return (
    <div className="bg-[var(--lp-bg-elev)] hairline-t hairline-b overflow-hidden">
      <div className="relative py-4">
        <div className="flex whitespace-nowrap marquee gap-10 label-code">
          {doubled.map((t, i) => (
            <span key={i} className="flex items-center gap-3 text-white/55">
              {t}
              <span className="text-[var(--sw-red)]">·</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  );
}

/* ------------------------------------------------------------------
   Problem — tighter, 3 pair-flips
   ------------------------------------------------------------------ */

function Problem() {
  const pairs = [
    {
      before: "Your batch export is a calendar event someone has to run.",
      after: "It runs overnight. Nobody watches it.",
    },
    {
      before: "Your school portal is an inbox, not a self-service tool.",
      after: "Schools update their own rosters. Your team stays out of it.",
    },
    {
      before: "Student data is scattered across five systems and a spreadsheet.",
      after: "One source of truth. Audit-logged end to end.",
    },
  ];

  return (
    <section className="section bg-[var(--lp-bg)]" id="problem">
      <div className="wrap">
        <div className="max-w-[64ch]">
          <SectionLabel index="§02">What the accelerator fixes</SectionLabel>
          <h2 className="font-head text-[32px] md:text-[52px] leading-tight">
            School photography is contract-based operations.{" "}
            <span className="text-white/45">Not retail.</span>
          </h2>
          <p className="mt-5 text-white/75 leading-relaxed max-w-[58ch]">
            Schools under contract. Students as subjects. Parents as buyers.
            Hard seasonal peak. Legacy systems nobody wants to touch. The
            accelerator replaces the parts that cost you the most — without
            asking you to rebuild what already works.
          </p>
        </div>

        <div className="mt-14 grid gap-5 md:gap-6 md:grid-cols-3">
          {pairs.map((p, i) => (
            <div
              key={i}
              className="rounded-[4px] border border-white/10 bg-[var(--lp-bg-card)] overflow-hidden"
            >
              <div className="p-6">
                <div className="label-code mb-3 text-[var(--sw-red)]">BEFORE · {String(i + 1).padStart(2, "0")}</div>
                <p className="text-white/85 text-[15px] leading-relaxed">{p.before}</p>
              </div>
              <div className="p-6 hairline-t bg-[var(--lp-bg-row)]">
                <div className="label-code mb-3 text-[var(--sw-green)]">AFTER</div>
                <p className="text-white font-medium text-[15px] leading-relaxed">{p.after}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}

/* ------------------------------------------------------------------
   Outcomes — 6 modules reframed as delivered outcomes with SVGs
   ------------------------------------------------------------------ */

/* Per-outcome SVGs — abstract schematic illustrations */

function SvgPortalOutcome() {
  return (
    <svg viewBox="0 0 520 320" className="w-full h-auto" role="img" aria-label="Self-service portal — schools stop calling your team">
      {/* BEFORE column */}
      <g transform="translate(24,24)">
        <text x="0" y="0" fill="#e04f4f" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">BEFORE</text>
        {/* Your team — overwhelmed */}
        <rect x="80" y="100" width="80" height="50" rx="2" fill="#10132c" stroke="#e04f4f" strokeWidth="1.5" />
        <text x="120" y="131" fill="#fff" fontSize="11" fontFamily="Inter" fontWeight="600" textAnchor="middle">YOUR TEAM</text>
        {/* School calls funneled in */}
        {[0, 25, 50, 75, 100, 125].map((y, i) => (
          <g key={i}>
            <line x1="0" y1={y + 25} x2="70" y2="125" stroke="#e04f4f" strokeWidth="1" opacity={i % 2 ? 0.9 : 0.5} />
            <circle cx="0" cy={y + 25} r="3" fill="#e04f4f" />
          </g>
        ))}
        <text x="0" y="180" fill="#8d91a8" fontSize="9" fontFamily="JetBrains Mono">6 schools · roster fixes · image pulls</text>
      </g>

      {/* Divider */}
      <line x1="260" y1="40" x2="260" y2="280" stroke="#e6e7ef" strokeOpacity="0.1" strokeDasharray="3 4" />

      {/* AFTER column */}
      <g transform="translate(280,24)">
        <text x="0" y="0" fill="#7de04f" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">AFTER</text>
        {/* Portal in the middle */}
        <rect x="70" y="90" width="80" height="50" rx="2" fill="#1f2346" stroke="#7de04f" strokeWidth="1.5" />
        <text x="110" y="113" fill="#fff" fontSize="11" fontFamily="Inter" fontWeight="600" textAnchor="middle">PORTAL</text>
        <text x="110" y="127" fill="#7de04f" fontSize="8" fontFamily="JetBrains Mono" textAnchor="middle">SELF-SERVICE</text>
        {/* Schools connecting to portal */}
        {[0, 25, 50, 75, 100, 125].map((y, i) => (
          <g key={i}>
            <line x1="0" y1={y + 25} x2="70" y2="115" stroke="#7de04f" strokeWidth="1" opacity="0.55" />
            <circle cx="0" cy={y + 25} r="3" fill="#7de04f" />
          </g>
        ))}
        {/* One escalation through to team */}
        <line x1="150" y1="115" x2="200" y2="115" stroke="#3f4aaf" strokeWidth="1" strokeDasharray="3 3" />
        <rect x="200" y="100" width="24" height="30" rx="2" fill="#10132c" stroke="#e6e7ef" strokeOpacity="0.15" strokeWidth="1" />
        <text x="212" y="119" fill="#8d91a8" fontSize="8" fontFamily="JetBrains Mono" textAnchor="middle">ESC</text>
        <text x="0" y="180" fill="#8d91a8" fontSize="9" fontFamily="JetBrains Mono">6 schools · 0 tickets · 1 escalation</text>
      </g>
    </svg>
  );
}

function SvgBatchExport() {
  return (
    <svg viewBox="0 0 520 320" className="w-full h-auto" role="img" aria-label="Batch exports run themselves — scheduled overnight automation">
      <g transform="translate(24,24)">
        <text x="0" y="0" fill="#e04f4f" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">BEFORE · 09:00 MON</text>
        <circle cx="40" cy="80" r="30" fill="none" stroke="#e04f4f" strokeWidth="1.5" />
        <text x="40" y="86" fill="#e04f4f" fontSize="18" fontFamily="Inter" fontWeight="700" textAnchor="middle">⏱</text>
        <text x="90" y="72" fill="#fff" fontSize="13" fontFamily="Inter" fontWeight="600">manual run</text>
        <text x="90" y="92" fill="#8d91a8" fontSize="11" fontFamily="JetBrains Mono">3h · inconsistent · fragile</text>

        <text x="0" y="190" fill="#7de04f" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">AFTER · 03:00 DAILY</text>
        <rect x="12" y="220" width="56" height="56" rx="2" fill="#1f2346" stroke="#7de04f" strokeWidth="1.5" />
        <text x="40" y="254" fill="#7de04f" fontSize="18" fontFamily="Inter" fontWeight="700" textAnchor="middle">⚙</text>
        <text x="90" y="242" fill="#fff" fontSize="13" fontFamily="Inter" fontWeight="600">CRON · automated</text>
        <text x="90" y="262" fill="#8d91a8" fontSize="11" fontFamily="JetBrains Mono">10 formats · audit-logged</text>
      </g>

      <g transform="translate(280,36)">
        {/* Timeline bar */}
        <text x="0" y="0" fill="#8d91a8" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">WEEKLY TIMELINE</text>
        {["MON","TUE","WED","THU","FRI","SAT","SUN"].map((d, i) => (
          <g key={d} transform={`translate(0,${40 + i * 32})`}>
            <text x="0" y="10" fill="#8d91a8" fontSize="10" fontFamily="JetBrains Mono">{d}</text>
            <rect x="38" y="0" width="180" height="14" rx="2" fill="#262a55" />
            <rect x={38 + (i * 12)} y="0" width="28" height="14" rx="2" fill="#7de04f" opacity="0.85" />
            <text x="224" y="10" fill="#e6e7ef" fontSize="9" fontFamily="JetBrains Mono">03:00 · auto</text>
          </g>
        ))}
      </g>
    </svg>
  );
}

function SvgDataModel() {
  return (
    <svg viewBox="0 0 520 320" className="w-full h-auto" role="img" aria-label="Five legacy systems collapse into one audit-logged graph">
      {/* Before: 5 scattered DBs */}
      <g transform="translate(20,40)">
        <text x="0" y="0" fill="#e04f4f" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">BEFORE · 5 SYSTEMS</text>
        {[
          ["GlobalJade", 10, 20],
          ["ImageDB", 70, 58],
          ["The Hub", 0, 96],
          ["CRM", 80, 134],
          ["eWay", 20, 172],
        ].map(([n, x, y], i) => (
          <g key={i} transform={`translate(${x},${y})`}>
            <ellipse cx="30" cy="10" rx="30" ry="5" fill="#10132c" stroke="#e04f4f" strokeWidth="1" />
            <rect x="0" y="10" width="60" height="24" fill="#10132c" stroke="#e04f4f" strokeWidth="1" />
            <ellipse cx="30" cy="34" rx="30" ry="5" fill="#10132c" stroke="#e04f4f" strokeWidth="1" />
            <text x="30" y="26" fill="#fff" fontSize="9" fontFamily="Inter" textAnchor="middle" fontWeight="600">{n}</text>
          </g>
        ))}
      </g>

      {/* Arrow */}
      <g transform="translate(210,160)">
        <line x1="0" y1="0" x2="60" y2="0" stroke="#e6e7ef" strokeOpacity="0.3" strokeWidth="1" />
