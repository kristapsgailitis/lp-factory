}

function SvgSSO() {
  return (
    <svg viewBox="0 0 520 320" className="w-full h-auto" role="img" aria-label="Dual SSO + audit">
      <g transform="translate(40,36)">
        {/* Left: 3 identity providers converging */}
        <text x="0" y="0" fill="#8d91a8" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">IDENTITY</text>
        {[
          ["AWS Cognito", "SCHOOL ADMINS", 20, "#3f4aaf"],
          ["Microsoft Entra ID", "INTERNAL STAFF", 96, "#3f4aaf"],
          ["Google OAuth", "PARENTS", 172, "#e04f4f"],
        ].map(([k, v, y, c], i) => (
          <g key={i} transform={`translate(0,${y as number})`}>
            <rect width="140" height="48" rx="2" fill="#1f2346" stroke={c as string} strokeWidth="1" />
            <text x="12" y="20" fill="#fff" fontSize="11" fontFamily="Inter" fontWeight="600">{k as string}</text>
            <text x="12" y="36" fill="#8d91a8" fontSize="9" fontFamily="JetBrains Mono">{v as string}</text>
            <line x1="140" y1="24" x2="180" y2="24" stroke={c as string} strokeWidth="1" />
            <circle cx="180" cy="24" r="3" fill={c as string} />
          </g>
        ))}
      </g>

      {/* Center: lock */}
      <g transform="translate(230,120)">
        <circle cx="30" cy="30" r="30" fill="#10132c" stroke="#7de04f" strokeWidth="1.5" />
        <rect x="18" y="24" width="24" height="18" rx="2" fill="none" stroke="#7de04f" strokeWidth="1.5" />
        <path d="M22 24 V18 a8 8 0 0 1 16 0 V24" fill="none" stroke="#7de04f" strokeWidth="1.5" />
        <circle cx="30" cy="34" r="2" fill="#7de04f" />
        <text x="30" y="78" fill="#7de04f" fontSize="9" fontFamily="JetBrains Mono" textAnchor="middle">AUDIT · ALL EVENTS</text>
      </g>

      {/* Right: audit log stream */}
      <g transform="translate(330,36)">
        <text x="0" y="0" fill="#8d91a8" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">AUDIT LOG</text>
        {[
          ["09:42:11", "school.ADMIN login"],
          ["09:42:58", "student.edit · 114 rows"],
          ["09:44:03", "export.start · grade-5"],
          ["09:47:18", "order.create · #3104"],
          ["09:49:45", "parent.login OAUTH"],
          ["09:52:02", "export.done · 4.2MB"],
        ].map(([t, m], i) => (
          <g key={i} transform={`translate(0,${20 + i * 30})`}>
            <text x="0" y="8" fill="#8d91a8" fontSize="9" fontFamily="JetBrains Mono">{t}</text>
            <rect x="54" y="0" width="6" height="12" fill="#7de04f" opacity={0.5 + i * 0.08} />
            <text x="68" y="10" fill="#e6e7ef" fontSize="10" fontFamily="JetBrains Mono">{m}</text>
          </g>
        ))}
      </g>
    </svg>
  );
}

