        {["REST","GraphQL","SOAP","webhooks","Kafka/SQS","SFTP","EDI"].map((p, i) => (
          <g key={p} transform={`translate(16, ${76 + i * 16})`}>
            <circle cx="4" cy="4" r="2" fill="#7de04f" opacity={0.5 + i * 0.06} />
            <text x="14" y="8" fill="#e6e7ef" fontSize="10" fontFamily="JetBrains Mono">{p}</text>
          </g>
        ))}
      </g>

      {/* Right: new systems */}
      <g transform="translate(380,40)">
        <text x="0" y="0" fill="#7de04f" fontSize="10" fontFamily="JetBrains Mono" letterSpacing="2">NEW · PRODUCTION</text>
        {["Pimcore MDM","Hyvä Commerce","School Portal","Batch Engine","ID Builder"].map((n, i) => (
          <g key={n} transform={`translate(0,${24 + i * 38})`}>
            <line x1="-30" y1="14" x2="0" y2="14" stroke="#7de04f" strokeWidth="1" />
            <circle cx="-30" cy="14" r="2.5" fill="#7de04f" />
            <rect width="110" height="28" rx="2" fill="#1f2346" stroke="#7de04f" strokeWidth="1" />
            <text x="12" y="18" fill="#fff" fontSize="11" fontFamily="Inter" fontWeight="500">{n}</text>
          </g>
        ))}
      </g>
    </svg>
  );
}

type OutcomeProps = {
  n: string;
  kicker: string;
  title: React.ReactNode;
  lede: string;
  results: string[];
  diagram: React.ReactNode;
  reverse?: boolean;
};

function OutcomeRow({ n, kicker, title, lede, results, diagram, reverse }: OutcomeProps) {
  return (
    <div className={`grid md:grid-cols-2 gap-10 md:gap-16 items-center`}>
      <div className={reverse ? "md:order-2" : "md:order-1"}>
        <div className="flex items-center gap-3 mb-5">
          <span className="label-code">OUTCOME.{n}</span>
          <span className="h-px w-6 bg-white/15" />
          <span className="label-code text-white/55">{kicker}</span>
        </div>
        <h3 className="font-head text-[26px] md:text-[40px] leading-[1.08] tracking-tight mb-4">{title}</h3>
        <p className="text-white/75 mb-6 leading-relaxed max-w-[44ch]">{lede}</p>
        <ul className="space-y-2.5">
          {results.map((r, i) => (
            <li key={i} className="flex gap-3 text-[14px] text-white/85">
              <Check className="h-4 w-4 shrink-0 mt-0.5 text-[var(--sw-green)]" />
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
      <div className={reverse ? "md:order-1" : "md:order-2"}>
        <div className="rounded-[4px] border border-white/10 bg-[var(--lp-bg-card)] p-5 md:p-6">
          {diagram}
        </div>
      </div>
    </div>
  );
}

function Outcomes() {
  const items: OutcomeProps[] = [
    {
      n: "01",
      kicker: "Self-service school portal",
      title: (
        <>
          Schools <span className="text-[var(--sw-red)]">stop calling your team</span> for every small thing.
        </>
      ),
      lede:
        "Schools upload rosters, correct data, and download their images from a portal. Role-based access per school, per user type. Every action audit-logged.",
      results: [
        "Support queue stops growing term on term",
        "Region-aware IP allowlist (AU-only on the reference deployment)",
        "Escalations still possible — but they’re the exception, not the default",
      ],
      diagram: <SvgPortalOutcome />,
    },
    {
      n: "02",
      kicker: "Batch export engine",
      title: (
        <>
          Your weekly export <span className="text-[var(--sw-red)]">stops being a job.</span>
        </>
      ),
      lede:
        "Ten export formats, dynamic naming rules per school, running on a CRON schedule. Manual re-runs available from the portal with one click.",
      results: [
        "CRON-scheduled off-peak · no human in the loop",
        "SchoolCode-StudentID-Grade-Year.jpg name patterns per school",
        "Every export audit-logged — who, what, when, where it landed",
      ],
      diagram: <SvgBatchExport />,
      reverse: true,
    },
    {
      n: "03",
      kicker: "Student data model · Pimcore MDM",
      title: (
        <>
